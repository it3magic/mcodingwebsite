# BMW Vehicle Identification API Credentials
# Get these from the BMW Group Partner Portal (https://aos.bmwgroup.com)

# API Key (required) - Used in x-apikey header
BMW_API_KEY=your-api-key-here

# OAuth2 Credentials (required for authentication)
# Used to obtain Bearer token from https://auth.bmwgroup.com/auth/oauth2/machine2machine/access_token
BMW_CLIENT_ID=your-client-id
BMW_CLIENT_SECRET=your-client-secret

# Optional: Admin credentials for internal admin panel
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Zoho Books integration (Work Records → "Import from Zoho")
# Create a "Self Client" in the Zoho API Console (https://api-console.zoho.com)
# with scope: ZohoBooks.invoices.READ (add ZohoBooks.contacts.READ to also pull
# vehicle/registration from the customer record), then exchange the grant code
# for a refresh token. Organization ID is in Zoho Books → Settings → Organisations.
# ---------------------------------------------------------------------------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
# Region-specific accounts domain (must match where the token was created).
# EU (Ireland): https://accounts.zoho.eu  ·  US: https://accounts.zoho.com
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
# Optional: override the data API domain (otherwise taken from the token response)
# ZOHO_API_DOMAIN=https://www.zohoapis.eu
